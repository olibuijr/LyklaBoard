# Xcode / XcodeGen
*.xcodeproj
*.xcworkspace
xcuserdata/
DerivedData/
.build/
.swiftpm/

# XcodeGen cache
.xcodegen/

# Replay rig build output (traces/ has its own .gitignore for raw data + results)
ReplayRig/.derived/

# macOS
.DS_Store

# Python
__pycache__/
*.pyc

# Personal typing sessions — never commit (raw typed text + all derived
# reports: <id>-report.md, <id>-candidates.jsonl, AGGREGATE.md, aggregate.json).
tools/session-analyzer/sessions/
# Personal eval corpus — quotes real typed text (typo/intended/context), so it
# is gitignored even though it lives outside sessions/. Feeds tuning locally.
tools/session-analyzer/personal-eval.jsonl
# User-confirmed typo intents — derived from personal typing, same rule.
tools/session-analyzer/confirmed-intents.jsonl
# Personal-eval baseline — derived from personal-eval.jsonl's real typed
# text (typo|intended row keys), so it is gitignored just like the corpus it
# summarizes. Local-only; `type-eval personal --update-baseline` rewrites it.
scores/personal-baseline.json
