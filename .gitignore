# Xcode / XcodeGen
*.xcodeproj
*.xcworkspace
xcuserdata/
DerivedData/
.build/
.swiftpm/

# XcodeGen cache
.xcodegen/

# Replay rig build output (traces/ has its own .gitignore for raw data + results)
ReplayRig/.derived/

# macOS
.DS_Store

# Python
__pycache__/
*.pyc

# Personal typing sessions — never commit (raw typed text + all derived
# reports: <id>-report.md, <id>-candidates.jsonl, AGGREGATE.md, aggregate.json).
tools/session-analyzer/sessions/
# Personal eval corpus — quotes real typed text (typo/intended/context), so it
# is gitignored even though it lives outside sessions/. Feeds tuning locally.
tools/session-analyzer/personal-eval.jsonl
# User-confirmed typo intents — derived from personal typing, same rule.
tools/session-analyzer/confirmed-intents.jsonl
# Dedicated venv for the OPTIONAL Greynir grammar-parse enrichment (reynir +
# islenska/BÍN data, downloaded on first use) — see README.md's Setup section.
tools/session-analyzer/.venv/
# Greynir parse-result cache — quotes real typed sentences, same rule as
# sessions/.
tools/session-analyzer/.greynir-cache.json
# Personal-eval baseline — derived from personal-eval.jsonl's real typed
# text (typo|intended row keys), so it is gitignored just like the corpus it
# summarizes. Local-only; `type-eval personal --update-baseline` rewrites it.
scores/personal-baseline.json

# Xcode/SwiftPM build products anywhere in the tree
build/

# asccli project context (app id — tooling-local, not a secret but no need to track)
.asc/

# ReplayRig test-build derived data (any suffix)
ReplayRig/.derived*/

# Keycap USDZ bake byproducts — the .usdz packs its own textures, these loose PNGs are unused
App/Resources/keycap_albedo.png
App/Resources/keycap_normal.png
App/Resources/keycap_roughness.png

# Research-only reference repositories
.refrepos/
