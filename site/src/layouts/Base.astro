---
// Shared page shell: design tokens, reset, head boilerplate, footer.
// Pages own their content styles; this owns the foundation.
interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}
const { title, description, ogImage = "/keycap-fallback.png" } = Astro.props;
---

<!doctype html>
<html lang="is">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}
    <meta property="og:title" content="Lyklaborð" />
    {description && <meta property="og:description" content={description} />}
    <meta property="og:image" content={ogImage} />
    <meta name="color-scheme" content="light dark" />
    <link rel="icon" href="/favicon.png" type="image/png" />
    <style is:global>
      :root {
        --plastic: #d7d2c8;
        --bg: #faf9f6;
        --bg-raised: #f1efe9;
        --ink: #1c1b1a;
        --ink-soft: #55524d;
        --rule: #e3e0d8;
        color-scheme: light dark;
      }
      @media (prefers-color-scheme: dark) {
        :root {
          --bg: #1c1b1a;
          --bg-raised: #242220;
          --ink: #e8e5e0;
          --ink-soft: #a5a19a;
          --rule: #33302c;
        }
      }
      :root[data-theme="light"] {
        --bg: #faf9f6;
        --bg-raised: #f1efe9;
        --ink: #1c1b1a;
        --ink-soft: #55524d;
        --rule: #e3e0d8;
      }
      :root[data-theme="dark"] {
        --bg: #1c1b1a;
        --bg-raised: #242220;
        --ink: #e8e5e0;
        --ink-soft: #a5a19a;
        --rule: #33302c;
      }
      * {
        margin: 0;
        box-sizing: border-box;
      }
      html {
        background: var(--bg);
        color: var(--ink);
        font-family: ui-sans-serif, system-ui, -apple-system, "Segoe UI", Roboto,
          "Helvetica Neue", Arial, sans-serif;
        font-size: 17px;
        line-height: 1.6;
        -webkit-text-size-adjust: 100%;
      }
      body {
        min-height: 100dvh;
        display: flex;
        flex-direction: column;
      }
      a {
        color: inherit;
        text-decoration-thickness: 1px;
        text-underline-offset: 0.18em;
      }
      footer {
        margin-top: clamp(4rem, 10vh, 7rem);
        border-top: 1px solid var(--rule);
        padding: 1.6rem 1.5rem 2.2rem;
        text-align: center;
        font-size: 0.8rem;
        color: var(--ink-soft);
      }
      @media (prefers-reduced-motion: reduce) {
        html {
          scroll-behavior: auto;
        }
      }
    </style>
  </head>
  <body>
    <slot />
    <footer>
      <p>
        MIT-leyfi · BÍN © Stofnun Árna Magnússonar í íslenskum fræðum · Smíðað á
        Íslandi
      </p>
    </footer>
  </body>
</html>
