---
// Privacy policy page — content synced from docs/PRIVACY.md at build time
// (see package.json "build"). Canonical URL for the App Store metadata.
import Base from "../layouts/Base.astro";
import { Content } from "../content/privacy.md";
const title = "Lyklaborð — persónuverndarstefna / privacy policy";
---

<Base title={title}>
  <header class="site">
    <a href="/">Lyklaborð <span>· persónuvernd</span></a>
  </header>
  <main>
    <Content />
  </main>

  <style is:global>
    header.site {
      width: min(44rem, 100%);
      margin: 0 auto;
      padding: 2.6rem 1.5rem 0;
    }
    header.site a {
      text-decoration: none;
      font-weight: 650;
      letter-spacing: -0.02em;
      font-size: 1.35rem;
    }
    header.site a span {
      color: var(--ink-soft);
      font-weight: 450;
    }
    main {
      width: min(44rem, 100%);
      margin: 0 auto;
      padding: 1.2rem 1.5rem 4rem;
      flex: 1;
      line-height: 1.65;
    }
    main h1 {
      font-size: clamp(1.5rem, 4vw, 2rem);
      font-weight: 650;
      letter-spacing: -0.02em;
      line-height: 1.2;
      margin-top: 1.6rem;
    }
    main h2 {
      margin-top: 3rem;
      padding-bottom: 0.4rem;
      border-bottom: 1px solid var(--rule);
      font-size: 1.3rem;
      letter-spacing: -0.01em;
    }
    main h3 {
      margin-top: 1.9rem;
      font-size: 1.05rem;
    }
    main p,
    main li {
      margin-top: 0.8rem;
    }
    main ul {
      padding-left: 1.2rem;
    }
    main blockquote {
      margin: 1.4rem 0;
      padding: 0.7rem 1.1rem;
      background: var(--bg-raised);
      border-left: 3px solid var(--rule);
      border-radius: 0 8px 8px 0;
      color: var(--ink-soft);
    }
    main blockquote p:first-child {
      margin-top: 0;
    }
    main code {
      font-family: ui-monospace, "SF Mono", Menlo, monospace;
      font-size: 0.88em;
      background: var(--bg-raised);
      padding: 0.1em 0.35em;
      border-radius: 5px;
    }
    main hr {
      border: none;
      border-top: 1px solid var(--rule);
      margin: 2.6rem 0;
    }
    main strong {
      font-weight: 650;
    }
  </style>
</Base>
