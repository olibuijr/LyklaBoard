{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "lyklabord-site",
  "compatibility_date": "2026-07-01",
  "assets": {
    "directory": "./dist",
    "not_found_handling": "404-page"
  },
  "routes": [
    {
      "pattern": "lyklabord.solberg.is",
      "custom_domain": true
    }
  ]
}
